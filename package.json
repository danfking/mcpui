{
  "name": "burnish",
  "version": "0.1.1",
  "private": true,
  "description": "Universal UI layer for MCP servers",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r build && pnpm --filter demo dev",
    "dev:nomodel": "pnpm -r build && pnpm --filter demo dev:nomodel",
    "test": "npx playwright test",
    "test:ci": "npx playwright test --project=chromium",
    "clean": "pnpm -r clean",
    "prepare": "git config core.hooksPath .githooks"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cross-env": "^10.1.0"
  }
}
